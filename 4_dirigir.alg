algoritmo "dirigir"
// F9: Executa o cůdigo

// Autor: Thiago Marcelino Vieira
// Disciplina: LOPAL
// Data: 13/04/2026
var
   idade: inteiro
inicio
   // Entrada
   escreva ("Informe uma idade: ")
   leia (idade)
   
   // Processo
   se idade >= 18 entao
   // SaŪda
      limpatela
      escreva ("Pode dirigir!")
   senao
      limpatela
      escreva ("Ainda n„o pode dirigir...")
   fimse
   
fimalgoritmo
